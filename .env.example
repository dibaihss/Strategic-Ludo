# Example env file for sharing required variable names (no secrets)

# App environment
NODE_ENV=production
APP_ENV=production

# API endpoints
REACT_APP_PRODUCTION_URL=https://api.example.com
REACT_APP_STAGING_URL=https://staging-api.example.com
REACT_APP_API_URL=https://api.example.com/v1

# WebSocket endpoint
REACT_APP_WS_URL=wss://ws.example.com
REACT_APP_SOCKET_URL=https://socket.example.com
REACT_APP_SOCKET_PATH=/socket.io
REACT_APP_SOCKET_AUTH_TOKEN=
REACT_APP_RT_TRANSPORT=socketio

# Third-party keys (placeholders)
REACT_APP_GOOGLE_ANALYTICS_ID=UA-XXXXX-Y
REACT_APP_SENTRY_DSN=
REACT_APP_FIREBASE_API_KEY=

# Feature flags
REACT_APP_ENABLE_LOGGING=false

EXPO_PUBLIC_LOCALHOST_API_URL=http://localhost:5000/api
